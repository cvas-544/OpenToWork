# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database (AWS RDS PostgreSQL)
DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/jobhunt

# Apify — private account (your own actors: Indeed scraper)
APIFY_TOKEN=apify_api_...

# Apify — public account (public actors: LinkedIn scraper)
APIFY_TOKEN_PUBLIC=apify_api_...

# Gmail OAuth (via n8n credential store — not needed here directly)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# n8n
N8N_WEBHOOK_URL=http://your-ec2-ip:5678

# Arbeitsagentur (public key — no registration needed)
ARBEITSAGENTUR_API_KEY=jobboerse-jobsuche

# Local LLM toggle — set to 1 to skip Claude and use Ollama (gemma2:9b) for all agents
# USE_LOCAL_LLM=1
# OLLAMA_BASE_URL=http://localhost:11434
