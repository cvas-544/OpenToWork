{
  "name": "OpenToWork — Daily Pipeline",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 8 * * 1-5" },
            { "field": "cronExpression", "expression": "0 12 * * 1-5" },
            { "field": "cronExpression", "expression": "0 20 * * 1-5" }
          ]
        }
      },
      "id": "schedule-daily",
      "name": "Schedule — 8am/Noon/8pm (Mon–Fri)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://agents:8000/run/agent1",
        "options": { "timeout": 600000 }
      },
      "id": "agent1",
      "name": "Agent 1 — Job Scraper",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://agents:8000/run/agent2",
        "options": { "timeout": 1800000 }
      },
      "id": "agent2",
      "name": "Agent 2 — CV Matcher",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://agents:8000/run/agent3",
        "options": { "timeout": 600000 }
      },
      "id": "agent3",
      "name": "Agent 3 — Gap Analyst",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://agents:8000/run/agent4",
        "options": { "timeout": 300000 }
      },
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 9 * * 0" }
          ]
        }
      },
      "id": "schedule-weekly",
      "name": "Schedule — Weekly (Sun 9am)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://agents:8000/run/agent5",
        "options": { "timeout": 600000 }
      },
      "id": "agent5",
      "name": "Agent 5 — Reporter",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://agents:8000/run/agent6",
        "options": { "timeout": 60000 }
      },
      "id": "agent6",
      "name": "Agent 6 — App Tracker (Follow-ups)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 500]
    }
  ],
  "connections": {
    "Schedule — 8am/Noon/8pm (Mon–Fri)": {
      "main": [[{ "node": "Agent 1 — Job Scraper", "type": "main", "index": 0 }]]
    },
    "Agent 1 — Job Scraper": {
      "main": [[{ "node": "Agent 2 — CV Matcher", "type": "main", "index": 0 }]]
    },
    "Agent 2 — CV Matcher": {
      "main": [[{ "node": "Agent 3 — Gap Analyst", "type": "main", "index": 0 }]]
    },
    "Schedule — Weekly (Sun 9am)": {
      "main": [[{ "node": "Agent 5 — Reporter", "type": "main", "index": 0 }]]
    },
    "Agent 5 — Reporter": {
      "main": [[{ "node": "Agent 6 — App Tracker (Follow-ups)", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "staticData": null,
  "tags": ["opentowork", "pipeline"],
  "meta": {
    "instanceId": "opentowork"
  }
}
